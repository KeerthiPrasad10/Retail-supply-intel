# Web dashboard configuration. Copy to .env.local for local dev; set the same
# variables in Vercel (Project Settings -> Environment Variables) for deploys.
#
# Optional — until set, the dashboard reads the committed snapshot
# (web/lib/snapshot.json) and getSupabase() returns null. When provisioned,
# lib/data.ts can switch to live Supabase queries.
#
# From Supabase Dashboard -> Project Settings -> API:
#   Project URL                  -> NEXT_PUBLIC_SUPABASE_URL
#   Project API keys (anon/public) -> NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# "Validate" feature (submit a product idea -> multi-agent research) — all
# server-side only. Each is optional: with none set, the pipeline returns
# deterministic demo data so the page still works.
# ---------------------------------------------------------------------------
# Anthropic key (classifier + strategy analyst). ANTHROPIC_API_KEY is already
# used by the existing /api/extract route; the research routes also accept the
# pipeline's RSI_ANTHROPIC_API_KEY as a fallback.
ANTHROPIC_API_KEY=
# Firecrawl (web research + per-page product extraction).
FIRECRAWL_API_KEY=
# Apify (Amazon online-store listings + AliExpress China suppliers).
APIFY_API_TOKEN=
# Service-role Supabase access for trusted writes (product_ideas, suppliers,
# competitors, triggers). NEVER prefix with NEXT_PUBLIC. SUPABASE_URL falls back
# to NEXT_PUBLIC_SUPABASE_URL when unset. With these unset, ideas persist to an
# in-memory store for the session.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
