# Retail Supply Intel — pipeline configuration (prefix RSI_).
# Copy to .env and adjust. All values are optional for local dev.

# Database (writes). Unset / empty -> local SQLite at ./data/rsi.db.
# For Supabase/Postgres use the connection string (install: uv sync --extra postgres).
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI,
# then prefix the scheme with `+psycopg`:
#   RSI_DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# (Use the Session pooler URI on port 6543 for serverless/pooled connections.)
RSI_DATABASE_URL=

# UN Comtrade free-tier subscription key (optional; preview endpoint used without it).
# Register at https://comtradedeveloper.un.org/
RSI_COMTRADE_API_KEY=
